      "scope": "scss,css",
      "prefix": "hzb",
      "body": [
         "//Заполнение фона вниз(Ставить ссылке)\nposition: relative;\nspan {\n\tposition: relative;\n\tz-index: 2;\n}\nbody.js_s-mouse &:hover {\n\t&:after{\n\t\tbottom: 0;\n\t\theight: 100%;\n\t}\n}\nbody.js_s-mouse &:active{\n\t&:after{\n\t\tleft: 50%;\n\t\ttransform: translate(-50%, 0);\n\t\twidth: 0%;\n\t}\n}\n&:after {\n\tcontent: \"\";\n\tposition: absolute;\n\tbottom: 100%;\n\tleft: 0%;\n\twidth: 100%;\n\theight: 0%;\n\tbackground-color: ${1:#999};\n\t@include transition();\n\tz-index: 1;\n}"
      ]
