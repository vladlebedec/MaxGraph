   "Заполнение фона влево": {
      "scope": "scss,css",
      "prefix": "hzl",
      "body": [
         "//Заполнение фона влево(Ставить ссылке)\nposition: relative;\nspan {\n\tposition: relative;\n\tz-index: 2;\n}\nbody.js_s-mouse &:hover {\n\t&:after{\n\t\tleft: 0;\n\t\twidth: 100%;\n\t}\n}\nbody.js_s-mouse &:active{\n\t&:after{\n\t\ttop: 50%;\n\t\ttransform: translate(0, -50%);\n\t\theight: 0%;\n\t}\n}\n&:after {\n\tcontent: \"\";\n\tposition: absolute;\n\tleft: 100%;\n\ttop: 0%;\n\twidth: 0%;\n\theight: 100%;\n\tbackground-color: ${1:#999};\n\t@include transition();\n\tz-index: 1;\n}"
      ]
   },
   "Заполнение фона вправо": {
      "scope": "scss,css",
      "prefix": "hzr",
      "body": [
         "//Заполнение фона вправо(Ставить ссылке)\nposition: relative;\nspan {\n\tposition: relative;\n\tz-index: 2;\n}\nbody.js_s-mouse &:hover {\n\t&:after{\n\t\tright: 0;\n\t\twidth: 100%;\n\t}\n}\nbody.js_s-mouse &:active{\n\t&:after{\n\t\ttop: 50%;\n\t\ttransform: translate(0, -50%);\n\t\theight: 0%;\n\t}\n}\n&:after {\n\tcontent: \"\";\n\tposition: absolute;\n\tright: 100%;\n\ttop: 0%;\n\twidth: 0%;\n\theight: 100%;\n\tbackground-color: ${1:#999};\n\t@include transition();\n\tz-index: 1;\n}"
      ]
   },
   "Пульсация": {
      "scope": "scss,css",
      "prefix": "hpp",
      "body": [
         "//Пульсация(Ставить ссылке)\n@include transition();\nbackground-color: ${1:#fff};\nbox-shadow: 0 0 0 0 rgba(#fff, 0.7);\nanimation: pulse 1.75s infinite cubic-bezier(0.66, 0, 0, 1);\n@keyframes pulse {\n\tto {\n\t\tbox-shadow: 0 0 0 to-rem(30) rgba(#e6edff, 0);\n\t}\n}\nbody.js_s-mouse &:hover{\n\tanimation-duration: 2s;\n}\nbody.js_s-mouse &:active{\n\tanimation-duration: 0.5s;\n}"
      ]
   },
   "Загрузка": {
      "scope": "scss,css",
      "prefix": "load",
