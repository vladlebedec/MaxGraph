   "Тень при наведении": {
      "scope": "scss,css",
      "prefix": "hbtn",
      "body": [
         "//Тень при наведении",
         "position: relative;",
         "cursor: pointer;",
         "@include transition();",
         "box-shadow: 0 0 0 $1;",
         "top: 0;",
         "body.js_s-mouse &:hover {",
         "\tbox-shadow: 0 to-rem(10) 0 $2;",
         "\ttop: to-rem(-10);",
         "}"
      ]
   },
   "Стрелка при наведении": {
      "scope": "scss,css",
      "prefix": "ht",
      "body": [
         "//Стрелка при наведении",
         "position: relative;",
         "cursor: pointer;",
         "@include transition();",
         "&:before {",
         "\tcontent: \"\";",
         "\t@include transition();",
         "\tposition: absolute;",
         "\tleft: 0;",
         "\ttop: 50%;",
         "\ttransform: (translate(0, -50%));",
         "\topacity: 0;",
         "\twidth: 0;",
         "\theight: 0;",
         "\tborder-top: to-rem(5) solid transparent;",
         "\tborder-left: to-rem(10) solid $1;",
         "\tborder-bottom: to-rem(5) solid transparent;",
         "}",
         "body.js_s-mouse &:hover {",
         "\tpadding-left: to-rem(20);",
         "\t&:before {",
         "\t\topacity: 1;",
         "\t}",
         "}"
      ]
   },
   "Зачеркивание с маской": {
      "scope": "scss,css",
      "prefix": "hzm",
      "body": [
         "//Зачеркивание с маской",
         "position: relative;",
         "overflow: hidden;",
         "&:before {",
         "\tcontent: \"\";",
         "\tposition: absolute;",
         "\ttop: 50%;",
         "\tbackground: $1;",
         "\theight: to-rem(2);",
         "\tleft: 0;",
         "\twidth: 100%;",
         "\ttransform: translate(-101%, -50%);",
         "\t@include transition(0.7, 0, ease-in-out);",
         "}",
         "&:after {",
         "\tcontent: \"\";",
         "\tposition: absolute;",
         "\ttop: 0;",
         "\tleft: 0;",
         "\twidth: 100%;",
         "\theight: 100%;",
         "\tbackground: $2;",
         "\ttransform: translate3d(-100%, 0, 0);",
         "\t@include transition(0.7, 0, ease-in-out);",
         "}",
         "body.js_s-mouse &:hover:after {",
         "\ttransform: translate3d(100%, 0, 0);",
         "}",
         "body.js_s-mouse &:hover:before {",
         "\ttransform: translate(0, 0);",
         "}"
      ]
   },
   "Тряска": {
      "scope": "scss,css",
      "prefix": "hshack",
      "body": [
         "//Тряска",
         "body.js_s-mouse &:hover {",
         "\tanimation: shaking 1s ease 1;",
         "}",
         "@keyframes shaking {",
         "\t15% {",
         "\t\ttransform: (translateX(to-rem(5)));",
         "\t}",
         "\t30% {",
         "\t\ttransform: (translateX(to-rem(-5)));",
         "\t}",
         "\t50% {",
         "\t\ttransform: (translateX(to-rem(3)));",
         "\t}",
         "\t65% {",
         "\t\ttransform: (translateX(to-rem(-3)));",
         "\t}",
         "\t80% {",
         "\t\ttransform: (translateX(to-rem(2)));",
         "\t}",
         "\t100% {",
         "\t\ttransform: (translateX(0));",
         "\t}",
         "}"
      ]
   },
   //=======================================================================================================================================================================================================================================================
   "Подчеркивание с центра(Ставить ссылке)": {
      "scope": "scss,css",
      "prefix": "hpc",
      "body": [
         "//Подчеркивание с центра(Ставить ссылке)",
         "position: relative;",
         "@include transition();",
         "body.js_s-mouse &:hover {",
         "\t&:before {",
         "\t\twidth: 100%;",
         "\t}",
         "}",
         "&:before {",
         "\tcontent: \"\";",
         "\tposition: absolute;",
         "\tbackground-color: $1;",
         "\t@include transition();",
         "\theight: to-rem(1);",
         "\tbottom: 0%;",
         "\tleft: 50%;",
         "\twidth: 0%;",
         "\ttransform: (translate(-50%, 0));",
         "}"
      ]
   },
   "Подчеркивание слево при наведении": {
      "scope": "scss,css",
      "prefix": "hpl",
      "body": [
         "//Подчеркивание слева(Ставить ссылке)\nposition: relative;\n@include transition();\nbody.js_s-mouse &:hover {\n\t&:before{\n\t\twidth: 100%;\n\t}\n}\nbody.js_s-mouse &:active{\n\t&:before{\n\t\tleft: 100%;\n\t\twidth: 0;\n\t}\n}\n&:before {\n\tcontent: \"\";\n\tposition: absolute;\n\tbottom: 0;\n\tleft: 0%;\n\twidth: 0%;\n\tbackground-color: ${1:#000};\n\theight: to-rem(1);\n\t@include transition();\n}"
      ]
   },
   "Подчеркивание справа при наведении": {
      "scope": "scss,css",
      "prefix": "hpr",
      "body": [
         "//Подчеркивание слева(Ставить ссылке)\nposition: relative;\n@include transition();\nbody.js_s-mouse &:hover {\n\t&:before{\n\t\twidth: 100%;\n\t}\n}\nbody.js_s-mouse &:active{\n\t&:before{\n\t\tright: 100%;\n\t\twidth: 0;\n\t}\n}\n&:before {\n\tcontent: \"\";\n\tposition: absolute;\n\tbottom: 0;\n\tright: 0%;\n\twidth: 0%;\n\tbackground-color: $1;\n\theight: to-rem(1);\n\t@include transition();\n}"
      ]
   },
   "Подчеркивание слево на право": {
      "scope": "scss,css",
      "prefix": "hplr",
      "body": [
         "//Подчеркивание слево на право(Ставить ссылке)\nposition: relative;\n@include transition();\n&:after {\n\tcontent: \"\";\n\tposition: absolute;\n\twidth: 100%;\n\ttransform: scaleX(0);\n\theight: to-rem(2);\n\tbottom: 0;\n\tleft: 0;\n\tbackground-color: ${1:#333};\n\ttransform-origin: bottom right;\n\ttransition: transform 0.4s cubic-bezier(0.86, 0, 0.07, 1) 0s;\n}\nbody.js_s-mouse &:hover:after {\n\ttransform: (scaleX(1));\n\ttransform-origin: bottom left;\n}"
      ]
   },
   //=======================================================================================================================================================================================================================================================
   "Выезжающие границы при наведении": {
      "scope": "scss,css",
      "prefix": "hbc",
      "body": [
         "//Выезжающие границы по середине со всех сторон(Ставить ссылке)",
         "position: relative;",
         "span {",
         "\tposition: relative;",
         "\tz-index: 2;",
         "}",
         "&:before,",
         "&:after {",
         "\tcontent: \"\";",
         "\tposition: absolute;",
         "\tleft: 0%;",
         "\ttop: 0%;",
         "\twidth: 100%;",
         "\theight: 100%;",
         "\tborder-style: solid;",
         "\tborder-color: #000;",
         "\tborder-radius: to-rem(15);",
         "\t@include transition();",
         "}",
         "&:before {",
         "\tborder-width: to-rem(2) 0 to-rem(2) 0;",
         "\ttransform:  (scaleX(0));",
         "}",
         "&:after {",
         "\tborder-width: 0 to-rem(2) 0 to-rem(2);",
         "\ttransform:  (scaleY(0));",
         "}",
         "body.js_s-mouse &:hover:before,",
         "body.js_s-mouse &:hover:after {",
         "\ttransform:  (scale(1));",
         "}"
      ]
   },
   "Сверху и снизу выйзжают границы при наведении": {
      "scope": "scss,css",
      "prefix": "hbtb",
      "body": [
         "//Сверху и снизу выезжают границы(Ставить ссылке)",
         "position: relative;",
         "&:before,",
         "&:after {",
         "\tcontent: \"\";",
         "\tposition: absolute;",
         "\t@include transition();",
         "\twidth: 0%;",
         "\theight: to-rem(2);",
         "\tbackground: $1;",
         "}",
         "&:before {",
         "\tbottom: 0;",
         "\tleft: 0;",
         "}",
         "&:after {",
         "\ttop: 0;",
         "\tright: 0;\t",
         "}",
         "body.js_s-mouse &:hover:before,",
         "body.js_s-mouse &:hover:after {",
         "\twidth: 100%;",
         "}"
      ]
   },
   //=======================================================================================================================================================================================================================================================
   "Заполнение фона вверх": {
      "scope": "scss,css",
      "prefix": "hzt",
      "body": [
         "//Заполнение фона вверх(Ставить ссылке)\nposition: relative;\nspan {\n\tposition: relative;\n\tz-index: 2;\n}\nbody.js_s-mouse &:hover {\n\t&:after{\n\t\ttop: 0;\n\t\theight: 100%;\n\t}\n}\nbody.js_s-mouse &:active{\n\t&:after{\n\t\tleft: 50%;\n\t\ttransform: translate(-50%, 0);\n\t\twidth: 0%;\n\t}\n}\n&:after {\n\tcontent: \"\";\n\tposition: absolute;\n\ttop: 100%;\n\tleft: 0%;\n\twidth: 100%;\n\theight: 0%;\n\tbackground-color: ${1:#999};\n\t@include transition();\n\tz-index: 1;\n}"
      ]
   },
